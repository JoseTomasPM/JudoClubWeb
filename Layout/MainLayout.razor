@inherits LayoutComponentBase
@inject JudoClubWeb.Services.AuthService Auth
@inject NavigationManager Nav

<nav class="navbar">
    <a href="/">🥋 JudoClub</a>
    @if (Auth.IsLoggedIn)
    {
        <a href="/students">Alumnos</a>
        <a href="/sessions">Sesiones</a>
        @if (Auth.Role == "Admin")
        {
            <a href="/admin">Panel Admin</a>
        }
        <div class="nav-right">
            <span class="rol-label">@Auth.Role</span>
            <button class="btn btn-danger btn-sm" @onclick="Logout">Cerrar sesión</button>
        </div>
    }
    else
    {
        <div class="nav-right">
            <a href="/login">Iniciar sesión</a>
            <a href="/register">Registrarse</a>
        </div>
    }
</nav>

<main class="page-content">
    @Body
</main>

<footer class="footer">
    <p>© 2026 JudoClub. Todos los derechos reservados.</p>

@code {
    void Logout() { Auth.Logout(); Nav.NavigateTo("/login"); }
}