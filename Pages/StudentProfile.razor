@page "/students/{Id:int}"
@inject JudoClubWeb.Services.StudentService StudentSvc
@inject HttpClient Http
@using JudoClubWeb.Models
@using JudoClubWeb.Helpers

<AuthGuard>
    @if (loading)
    {
        <p>Cargando perfil...</p>
    }
    else if (student == null)
    {
        <p>Alumno no encontrado o sin acceso.</p>
        <a href="/students" class="back-link">← Volver</a>
    }
    else
    {
        <a href="/students" class="back-link">← Volver a la lista</a>

        <div class="card mt-md">
            <div class="flex gap-md" style="margin-bottom:16px">
                <div style="font-size:3em">🥋</div>
                <div>
                    <h2 style="margin:0">@student.Name</h2>
                    <p class="text-muted" style="margin:4px 0">@CategoryHelper.ToLabel(student.Category)</p>
                </div>
            </div>

            <h4>Datos personales</h4>
            <p><strong>Fecha de nacimiento:</strong> @student.BirthDate.ToString("dd/MM/yyyy")</p>
            <p><strong>Cinturón:</strong> @student.Belt</p>
            <p><strong>Categoría:</strong> @CategoryHelper.ToLabel(student.Category)</p>

            <div class="flex gap-sm mt-md">
                <a href="/students/@student.Id/payments" class="btn btn-primary btn-sm">💳 Ver pagos</a>
                <a href="/students/@student.Id/documents" class="btn btn-primary btn-sm">📄 Ver documentos</a>
            </div>
        </div>

        @if (sessions.Any())
        {
            <h4 class="mt-lg">Sesiones</h4>
            <div class="session-list">
                @foreach (var s in sessions)
                {
                    <div class="session-item">
                        <div>
                            <strong>@s.Date.ToString("dd/MM/yyyy HH:mm")</strong>
                            <p class="text-muted" style="margin:4px 0">@s.Description</p>
                        </div>
                        <a href="/sessions/@s.Id" class="btn btn-primary btn-sm">Ver →</a>
                    </div>
                }
            </div>
        }
    }
</AuthGuard>

@code {
    [Parameter] public int Id { get; set; }
    StudentDto? student;
    List<SessionDto> sessions = new();
    bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        student  = await StudentSvc.GetByIdAsync(Id);
        sessions = await Http.GetFromJsonAsync<List<SessionDto>>($"api/student/{Id}/sessions") ?? new();
        loading  = false;
    }
}