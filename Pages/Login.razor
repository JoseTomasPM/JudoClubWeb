@page "/login"
@inject JudoClubWeb.Services.AuthService Auth
@inject NavigationManager Nav

<div class="auth-container">
    <h3>Iniciar sesiÛn</h3>

    @if (error != null)
    {
        <p class="text-error">@error</p>
    }

    <div class="form-group">
        <label>Email</label>
        <input type="email" @bind="email" />
    </div>
    <div class="form-group">
        <label>ContraseÒa</label>
        <input type="password" @bind="password" />
    </div>

    <button class="btn btn-primary" @onclick="HandleLogin" disabled="@loading">
        @(loading ? "Entrando..." : "Entrar")
    </button>
</div>

@code {
    string email = "", password = "";
    string? error = null;
    bool loading = false;

    async Task HandleLogin()
    {
        loading = true; error = null;
        var ok = await Auth.LoginAsync(email, password);
        if (ok) Nav.NavigateTo("/");
        else error = "Email o contraseÒa incorrectos.";
        loading = false;
    }
}