@page "/students/{Id:int}/payments"
@inject HttpClient Http
@using JudoClubWeb.Models

<AuthGuard>
    <a href="/students/@Id">← Volver al perfil</a>
    <h3 style="margin-top:16px">Historial de pagos</h3>

    @if (loading)
    {
        <p>Cargando...</p>
    }
    else if (!payments.Any())
    {
        <p style="color:#888">No hay pagos registrados.</p>
    }
    else
    {
        <table style="width:100%; border-collapse:collapse; margin-top:16px;">
            <thead>
                <tr style="background:#1a1a2e; color:white; text-align:left;">
                    <th style="padding:10px">Concepto</th>
                    <th style="padding:10px">Importe</th>
                    <th style="padding:10px">Fecha</th>
                    <th style="padding:10px">Estado</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in payments)
                {
                    <tr style="border-bottom:1px solid #eee;">
                        <td style="padding:10px">@p.Concept</td>
                        <td style="padding:10px">@p.Amount.ToString("0.00") €</td>
                        <td style="padding:10px">@p.Date.ToString("dd/MM/yyyy")</td>
                        <td style="padding:10px">
                            <span style="padding:4px 10px; border-radius:12px; font-size:0.85em;
                                  background:@GetStatusColor(p.Status); color:white;">
                                @p.Status
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <p style="margin-top:12px; font-weight:bold;">
            Total pendiente: @payments.Where(p => p.Status == "Pending").Sum(p => p.Amount).ToString("0.00") €
        </p>
    }
</AuthGuard>

@code {
    [Parameter] public int Id { get; set; }
    List<PaymentDto> payments = new();
    bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        try { payments = await Http.GetFromJsonAsync<List<PaymentDto>>($"api/students/{Id}/payments") ?? new(); }
        catch { payments = new(); }
        loading = false;
    }

    string GetStatusColor(string status) => status switch
    {
        "Completed" => "#22c55e",
        "Failed"    => "#ef4444",
        _           => "#f59e0b"
    };
}