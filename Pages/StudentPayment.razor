@page "/students/{Id:int}/payments"
@inject HttpClient Http
@inject JudoClubWeb.Services.AuthService Auth
@using JudoClubWeb.Models

<AuthGuard>
    <a href="/students/@Id" class="back-link">← Volver al perfil</a>
    <div class="flex-between mt-md">
        <h3>Historial de pagos</h3>
    </div>

    @if (loading) { <p>Cargando...</p> }
    else if (!payments.Any()) { <p class="text-muted">No hay pagos registrados.</p> }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Concepto</th>
                    <th>Importe</th>
                    <th>Fecha</th>
                    <th>Estado</th>
                    @if (Auth.Role == "Admin") { <th>Acciones</th> }
                </tr>
            </thead>
            <tbody>
                @foreach (var p in payments)
                {
                    <tr>
                        <td>@p.Concept</td>
                        <td>@p.Amount.ToString("0.00") €</td>
                        <td>@p.Date.ToString("dd/MM/yyyy")</td>
                        <td><span class="badge @GetBadgeClass(p.Status)">@p.Status</span></td>
                        @if (Auth.Role == "Admin")
                        {
                            <td>
                                <div class="flex gap-sm">
                                    @if (p.Status != "Completed")
                                    {
                                        <button class="btn btn-success btn-sm" @onclick="() => ChangeStatus(p.Id, 1)">✅ Pagado</button>
                                    }
                                    @if (p.Status != "Failed")
                                    {
                                        <button class="btn btn-danger btn-sm" @onclick="() => ChangeStatus(p.Id, 2)">❌ Fallido</button>
                                    }
                                    <button class="btn btn-danger btn-sm" @onclick="() => DeletePayment(p.Id)">🗑️</button>
                                </div>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
        <p class="mt-md"><strong>Total pendiente: @payments.Where(p => p.Status == "Pending").Sum(p => p.Amount).ToString("0.00") €</strong></p>
    }
</AuthGuard>

@code {
    [Parameter] public int Id { get; set; }
    List<PaymentDto> payments = new();
    bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        await Load(); loading = false;
    }

    async Task Load()
    {
        try { payments = await Http.GetFromJsonAsync<List<PaymentDto>>($"api/students/{Id}/payments") ?? new(); }
        catch { payments = new(); }
    }

    async Task ChangeStatus(int paymentId, int status)
    {
        await Http.PutAsJsonAsync($"api/payments/{paymentId}/status", new { status });
        await Load();
    }

    async Task DeletePayment(int paymentId)
    {
        await Http.DeleteAsync($"api/students/{Id}/payments/{paymentId}");
        await Load();
    }

    string GetBadgeClass(string status) => status switch
    {
        "Completed" => "badge-success",
        "Failed"    => "badge-danger",
        _           => "badge-warning"
    };
}