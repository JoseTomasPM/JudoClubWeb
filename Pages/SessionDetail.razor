@page "/sessions/{Id:int}"
@inject HttpClient Http
@inject JudoClubWeb.Services.AuthService Auth
@inject NavigationManager Nav
@using JudoClubWeb.Models

<AuthGuard>
    @if (loading) { <p>Cargando...</p> }
    else if (session == null) { <p>Sesión no encontrada.</p> }
    else
    {
        <a href="/sessions" class="back-link">← Volver a sesiones</a>

        <div class="flex-between mt-md">
            <div>
                <h3 style="margin:0">@session.Date.ToString("dd/MM/yyyy HH:mm")</h3>
                <p class="text-muted">@session.Description</p>
                <p class="text-muted">@session.Category.ToString()</p>
                <span class="badge badge-primary" style="background:var(--primary)">
                    📁 @session.Category
                </span>
            </div>
            @if (Auth.Role == "Admin")
            {
                <div class="flex gap-sm">
                    <a href="/sessions/@Id/edit" class="btn btn-primary btn-sm">✏️ Editar</a>
                    <button class="btn btn-danger btn-sm" @onclick="DeleteSession">🗑️ Eliminar</button>
                </div>
            }
        </div>

        @* ── Resumen de asistencia ── *@
        <div class="card mt-lg">
            <strong>Asistencia: @students.Count(s => s.Attended) / @students.Count presentes</strong>
            <div style="background:#eee; border-radius:4px; height:8px; margin-top:8px;">
                <div style="background:var(--success); height:8px; border-radius:4px;
                            width:@(students.Count > 0 ? (students.Count(s => s.Attended) * 100 / students.Count) : 0)%">
                </div>
            </div>
        </div>

        <h4 class="mt-lg">
            Alumnos — @session.Category (@students.Count)
        </h4>

        @if (Auth.Role == "Admin")
        {
            <div class="flex gap-sm mt-sm" style="margin-bottom:16px">
                <input type="number" @bind="studentIdToAdd" placeholder="ID alumno extra"
                       style="padding:6px; border:1px solid #ccc; border-radius:var(--radius); width:160px;" />
                <button class="btn btn-success btn-sm" @onclick="AddStudent">+ Añadir manualmente</button>
            </div>
            @if (addError != null) { <p class="text-error">@addError</p> }
        }

        @if (!students.Any()) { <p class="text-muted">No hay alumnos asignados.</p> }
        else
        {
            <div class="card-grid">
                @foreach (var s in students.OrderByDescending(s => s.Attended))
                {
                    <div class="card" style="min-width:170px; border-left:4px solid @(s.Attended ? "var(--success)" : "var(--border)")">
                        <strong>@s.Name</strong>
                        <p style="font-size:0.85em; margin:4px 0">🥋 @s.Belt</p>

                        @if (Auth.Role == "Admin")
                        {
                            <div class="flex gap-sm mt-sm">
                                @if (!s.Attended)
                                {
                                    <button class="btn btn-success btn-sm"
                                            @onclick="() => MarkAttendance(s.StudentId, true)">
                                        ✅ Presente
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-sm" style="background:#f0f0f0"
                                            @onclick="() => MarkAttendance(s.StudentId, false)">
                                        ↩️ Desmarcar
                                    </button>
                                }
                                <button class="btn btn-danger btn-sm"
                                        @onclick="() => RemoveStudent(s.StudentId)">🗑️</button>
                            </div>
                        }
                        else
                        {
                            <span style="font-size:0.85em">
                                @(s.Attended ? "✅ Presente" : "⬜ Ausente")
                            </span>
                        }
                    </div>
                }
            </div>
        }
    }
</AuthGuard>

@code {
    [Parameter] public int Id { get; set; }

    SessionDto? session;
    List<SessionStudentDto> students = new();
    int studentIdToAdd;
    string? addError;
    bool loading = true;

    protected override async Task OnInitializedAsync() { await Load(); loading = false; }

    async Task Load()
    {
        try
        {
            session  = await Http.GetFromJsonAsync<SessionDto>($"api/sessions/{Id}");
            students = await Http.GetFromJsonAsync<List<SessionStudentDto>>($"api/sessions/{Id}/students") ?? new();
        }
        catch { }
    }

    async Task MarkAttendance(int studentId, bool attended)
    {
        await Http.PutAsJsonAsync(
            $"api/sessions/{Id}/students/{studentId}/attendance",
            new { attended });

        // Actualizar localmente sin recargar todo
        var s = students.FirstOrDefault(x => x.StudentId == studentId);
        if (s != null) s.Attended = attended;
    }

    async Task AddStudent()
    {
        addError = null;
        var r = await Http.PostAsync($"api/sessions/{Id}/students/{studentIdToAdd}", null);
        if (r.IsSuccessStatusCode) { studentIdToAdd = 0; await Load(); }
        else addError = "No se pudo añadir. Verifica que el ID es correcto.";
    }

    async Task RemoveStudent(int studentId)
    {
        await Http.DeleteAsync($"api/sessions/{Id}/students/{studentId}");
        await Load();
    }

    async Task DeleteSession()
    {
        await Http.DeleteAsync($"api/sessions/{Id}");
        Nav.NavigateTo("/sessions");
    }
}