@page "/students/new"
@page "/students/{Id:int}/edit"
@inject HttpClient Http
@inject NavigationManager Nav
@using JudoClubWeb.Models

<AuthGuard RequiredRole="Admin">
    <a href="/students" class="back-link">← Volver</a>
    <h3 class="mt-md">@(Id == 0 ? "Nuevo alumno" : "Editar alumno")</h3>

    @if (error != null) { <p class="text-error">@error</p> }

    <div class="form-container mt-md">
        <div class="form-group">
            <label>Nombre</label>
            <input @bind="name" />
        </div>
        <div class="form-group">
            <label>Fecha de nacimiento</label>
            <input type="date" @bind="birthDate" />
        </div>
        <div class="form-group">
            <label>Cinturón</label>
            <select @bind="belt">
                <option value="0">Blanco</option>
                <option value="1">Blanco-Amarillo</option>
                <option value="2">Amarillo</option>
                <option value="3">Amarillo-Naranja</option>
                <option value="4">Naranja</option>
                <option value="5">Naranja-Verde</option>
                <option value="6">Verde</option>
                <option value="7">Verde-Azul</option>
                <option value="8">Azul</option>
                <option value="9">Azul-Marrón</option>
                <option value="10">Marrón</option>
                <option value="11">Negro 1º Dan</option>
                <option value="12">Negro 2º Dan</option>
                <option value="14">Negro 3º Dan</option>
                <option value="15">Negro 4º Dan</option>
                <option value="16">Negro 5º Dan</option>
                <option value="17">Rojo-Blanco 6º Dan</option>
                <option value="18">Rojo-Blanco 7º Dan</option>
                <option value="19">Rojo-Blanco 8º Dan</option>
                <option value="20">Rojo 9º Dan</option>
                <option value="21">Rojo 10º Dan</option>
            </select>
        </div>
        <div class="form-group">
            <label>Categoría</label>
            <select @bind="category">
                <option value="0">Benjamín (Sub-11)</option>
                <option value="1">Alevín (Sub-13)</option>
                <option value="2">Infantil (Sub-15)</option>
                <option value="3">Cadete (Sub-17)</option>
                <option value="4">Júnior (Sub-20)</option>
                <option value="5">Sub-23</option>
                <option value="6">Senior</option>
            </select>
        </div>
        @if (Id == 0)
        {
            <div class="form-group">
                <label>UserId del tutor</label>
                <input type="number" @bind="userId" />
            </div>
        }
        <button class="btn btn-primary" @onclick="HandleSubmit" disabled="@loading">
            @(loading ? "Guardando..." : (Id == 0 ? "Crear alumno" : "Guardar cambios"))
        </button>
    </div>
</AuthGuard>

@code {
    [Parameter] public int Id { get; set; }

    string name = "";
    DateTime birthDate = DateTime.Today;
    int belt = 0;
    int category = 0;
    int userId = 0;
    string? error;
    bool loading;

    protected override async Task OnInitializedAsync()
    {
        if (Id != 0)
        {
            var s = await Http.GetFromJsonAsync<StudentDto>($"api/student/{Id}");
            if (s != null)
            {
                name      = s.Name;
                birthDate = s.BirthDate;
                userId    = s.UserId;
                belt     = Enum.TryParse<BeltEnum>(s.Belt.Replace(" ", "").Replace("º", ""), out var b) ? (int)b : 0;
                category = Enum.TryParse<CategoryEnum>(s.Category, out var cat) ? (int)cat : 0;
            }
        }
    }

    async Task HandleSubmit()
    {
        loading = true; error = null;
        var body = new { name, birthDate, belt, category, userId = Id == 0 ? userId : (int?)null };
        var response = Id == 0
            ? await Http.PostAsJsonAsync("api/student", body)
            : await Http.PutAsJsonAsync($"api/student/{Id}", body);

        if (response.IsSuccessStatusCode)
            Nav.NavigateTo("/students");
        else
            error = "Error al guardar. Comprueba los datos.";
        loading = false;
    }

    enum CategoryEnum { Benjamin, Alevin, Infantil, Cadete, Junior, Sub23, Senior }
    enum BeltEnum { White, WhiteYellow, Yellow, YellowOrange, Orange, OrangeGreen, Green, GreenBlue, Blue, BlueBrown, Brown, Black1Dan, Black2Dan, Black3Dan }
}