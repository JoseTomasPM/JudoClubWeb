@page "/sessions/new"
@page "/sessions/{Id:int}/edit"
@inject HttpClient Http
@inject NavigationManager Nav

<AuthGuard RequiredRole="Admin">
    <a href="/sessions" class="back-link">← Volver</a>
    <h3 class="mt-md">@(Id == 0 ? "Nueva sesión" : "Editar sesión")</h3>

    @if (error != null) { <p class="text-error">@error</p> }

    <div class="form-container">
        <div class="form-group">
            <label>Fecha y hora</label>
            <input type="datetime-local" @bind="date" />
        </div>
        <div class="form-group">
            <label>Descripción</label>
            <input @bind="description" />
        </div>
        <button class="btn btn-primary" @onclick="HandleSubmit" disabled="@loading">
            @(loading ? "Guardando..." : (Id == 0 ? "Crear sesión" : "Guardar cambios"))
        </button>
    </div>
</AuthGuard>

@code {
    [Parameter] public int Id { get; set; }
    DateTime date = DateTime.Today;
    string description = "";
    string? error;
    bool loading;

    protected override async Task OnInitializedAsync()
    {
        if (Id != 0)
        {
            var s = await Http.GetFromJsonAsync<SessionDto>($"api/sessions/{Id}");
            if (s != null) { date = s.Date; description = s.Description; }
        }
    }

    async Task HandleSubmit()
    {
        loading = true; error = null;
        var body = new { date, description };
        var response = Id == 0
            ? await Http.PostAsJsonAsync("api/sessions", body)
            : await Http.PutAsJsonAsync($"api/sessions/{Id}", body);
        if (response.IsSuccessStatusCode) Nav.NavigateTo("/sessions");
        else error = "Error al guardar la sesión.";
        loading = false;
    }

    record SessionDto(int Id, DateTime Date, string Description, int StudentCount);
    record SessionStudentDto(int StudentId, string Name, string Belt);
}