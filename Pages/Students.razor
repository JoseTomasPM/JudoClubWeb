@page "/students"
@inject JudoClubWeb.Services.AuthService Auth
@inject JudoClubWeb.Services.StudentService StudentSvc
@inject HttpClient Http
@using JudoClubWeb.Models

<AuthGuard>
    <div class="flex-between">
        <h3>Alumnos</h3>
        @if (Auth.Role == "Admin")
        {
            <a href="/students/new" class="btn btn-primary">+ Nuevo alumno</a>
        }
    </div>

    @if (loading) { <p>Cargando...</p> }
    else if (!students.Any()) { <p class="text-muted">No hay alumnos registrados.</p> }
    else
    {
        <div class="card-grid mt-md">
            @foreach (var s in students)
            {
                <div class="card card-student">
                    <h4 style="margin:0 0 8px">@s.Name</h4>
                    <p>🥋 @s.Belt</p>
                    <p>📁 @s.Category</p>
                    <p class="text-muted" style="font-size:0.8em">@s.BirthDate.ToString("dd/MM/yyyy")</p>
                    <div class="flex gap-sm mt-sm">
                        <a href="/students/@s.Id" class="btn btn-primary btn-sm">Ver →</a>
                        @if (Auth.Role == "Admin")
                        {
                            <a href="/students/@s.Id/edit" class="btn btn-sm" style="background:#f0f0f0">✏️</a>
                            <button class="btn btn-danger btn-sm" @onclick="() => DeleteStudent(s.Id)">🗑️</button>
                        }
                    </div>
                </div>
            }
        </div>
    }
</AuthGuard>

@code {
    List<StudentDto> students = new();
    bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsLoggedIn) return;
        students = await StudentSvc.GetStudentsAsync(Auth.Role == "Admin");
        loading  = false;
    }

    async Task DeleteStudent(int id)
    {
        await Http.DeleteAsync($"api/student/{id}");
        students = await StudentSvc.GetStudentsAsync(Auth.Role == "Admin");
    }
}