@page "/students/{Id:int}/documents"
@inject HttpClient Http
@using JudoClubWeb.Models

<AuthGuard>
    <a href="/students/@Id" class="back-link">← Volver al perfil</a>
    <h3 class="mt-md">Documentos</h3>

    @if (loading) { <p>Cargando...</p> }
    else
    {
        @if (!documents.Any()) { <p class="text-muted">No hay documentos subidos.</p> }
        else
        {
            @foreach (var d in documents)
            {
                <div class="card flex-between mt-sm">
                    <div>
                        <strong>📄 @d.Name</strong>
                        <p class="text-muted">
                            Subido por @d.UploadBy · @d.UploadDate.ToString("dd/MM/yyyy")
                        </p>
                    </div>
                    <div class="flex gap-sm">
                        <a href="@d.Url" target="_blank" class="btn btn-primary btn-sm">Ver PDF</a>
                        <button class="btn btn-danger btn-sm" @onclick="() => DeleteDoc(d.Id)">🗑️</button>
                    </div>
                </div>
            }
        }

        <div class="upload-zone">
            <h4>Subir documento</h4>
            @if (uploadError != null) { <p class="text-error">@uploadError</p> }
            @if (uploadSuccess) { <p class="text-success">✅ Subido correctamente.</p> }
            <InputFile OnChange="OnFileSelected" accept=".pdf" />
            <button class="btn btn-primary mt-sm" @onclick="UploadFile"
                    disabled="@(selectedFile == null || uploading)">
                @(uploading ? "Subiendo..." : "Subir PDF")
            </button>
        </div>
    }
</AuthGuard>

@code {
    [Parameter] public int Id { get; set; }
    List<DocumentDto> documents = new();
    IBrowserFile? selectedFile;
    bool loading = true, uploading = false, uploadSuccess = false;
    string? uploadError;

    protected override async Task OnInitializedAsync() { await Load(); loading = false; }

    async Task Load()
    {
        try { documents = await Http.GetFromJsonAsync<List<DocumentDto>>($"api/students/{Id}/documents") ?? new(); }
        catch { documents = new(); }
    }

    async Task DeleteDoc(int docId)
    {
        await Http.DeleteAsync($"api/students/{Id}/documents/{docId}");
        await Load();
    }

    void OnFileSelected(InputFileChangeEventArgs e) { selectedFile = e.File; uploadSuccess = false; uploadError = null; }

    async Task UploadFile()
    {
        if (selectedFile == null) return;
        uploading = true; uploadError = null; uploadSuccess = false;
        try
        {
            using var content     = new MultipartFormDataContent();
            using var stream      = selectedFile.OpenReadStream(5 * 1024 * 1024);
            using var fileContent = new StreamContent(stream);
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue("application/pdf");
            content.Add(fileContent, "file", selectedFile.Name);
            var r = await Http.PostAsync($"api/students/{Id}/documents", content);
            if (r.IsSuccessStatusCode) { uploadSuccess = true; selectedFile = null; await Load(); }
            else uploadError = "Error al subir. Máximo 5MB y solo PDF.";
        }
        catch (Exception ex) { uploadError = $"Error: {ex.Message}"; }
        uploading = false;
    }
}